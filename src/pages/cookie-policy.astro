---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

const pageTitle = "Cookie Policy for Devosfera Load Test 03 20260519-063743875 Benchmark Audit";
const pageDescription = "How the site can explain essential cookies, analytics tools, and visitor controls in plain language.";
---

<Layout title={`${pageTitle} | ${SITE.title}`} description={pageDescription}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-16">
    <article class="app-prose mx-auto max-w-3xl">
      <header class="mb-10">
        <p class="font-cartograph text-sm uppercase tracking-wide text-accent">
          Site information
        </p>
        <h1>{pageTitle}</h1>
        <p class="text-foreground/70">{pageDescription}</p>
      </header>
      <section class="mb-10">
        <h2>What cookies are</h2>
        <p>Cookies are small pieces of data that can help a site remember settings, measure basic usage, and keep pages working as expected.</p>
        <p>This page stands on its own, but it should still be read together with the privacy policy when a fuller legal set is published.</p>
      </section>

      <section class="mb-10">
        <h2>Cookie categories</h2>
        <p>Essential cookies are used to keep the site functioning and to support basic navigation, security, and session behaviour.</p>
        <p>Preference cookies, if used, can help remember basic display choices or language settings.</p>
      </section>

      <section class="mb-10">
        <h2>Why the site may use these tools</h2>
        <p>Essential cookies can keep the site functioning, while other cookies may support preferences, analytics, or embedded media.</p>
        <p>If the site later adds a newsletter, comments, account areas, or tracking, the cookie policy should be updated before those features are public.</p>
      </section>

      <section class="mb-10">
        <h2>External services that may set cookies</h2>
        <p>Third-party technologies can include analytics platforms, embedded video players, map services, newsletter tools, or comment providers.</p>
        <p>The cookie policy should identify real services only when the site actually uses them.</p>
      </section>

      <section class="mb-10">
        <h2>How visitors can manage cookies</h2>
        <p>Visitors can usually manage cookies through browser settings and, where available, any site-level preference tools.</p>
        <p>If consent tools are introduced later, they should be explained clearly and should match the actual cookie behaviour of the site.</p>
      </section>

      <section class="mb-10">
        <h2>How cookie disclosures are updated</h2>
        <p>This page should be updated if analytics, embeds, or other third-party tools are added or removed.</p>
        <p>The wording should stay accurate to the live implementation rather than to any generic template assumption.</p>
      </section>

      <aside class="rounded-2xl border border-border/30 bg-muted/20 p-5 text-sm text-foreground/70">
        <p>This starter page is generated as a baseline and should be reviewed and customized before being relied on as production legal or business copy.</p>
      </aside>
    </article>
  </main>
  <Footer />
</Layout>
