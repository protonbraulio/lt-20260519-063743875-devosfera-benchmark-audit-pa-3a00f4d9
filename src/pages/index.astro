---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const [blogPosts, galleryPosts] = await Promise.all([
  getCollection("blog"),
  SITE.showGalleries && SITE.showGalleriesInIndex
    ? getCollection("galleries")
    : Promise.resolve([]),
]);
const posts = [...blogPosts, ...galleryPosts];

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => "featured" in data && data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !("featured" in data && data.featured));
---

<Layout title="Content Operations Benchmark" description="Summarize the benchmark model, score categories, and audit priorities for content operations in Austin. Key entities: Content Operations.">
  <Header />

  <main id="main-content" data-layout="index" class="relative app-layout">
    <section class="content-pack-homepage space-y-10">
      <header class="max-w-3xl space-y-4">
        <p class="text-sm font-semibold uppercase tracking-wide text-accent">Featured resource</p>
        <h1 class="text-4xl font-bold leading-tight md:text-5xl text-foreground">Content Operations Benchmark</h1>
        <p class="text-lg leading-8 text-foreground/75">Summarize the benchmark model, score categories, and audit priorities for content operations in Austin. Key entities: Content Operations.</p>
      </header>
      <nav class="space-y-3" aria-label="Table of contents">
        <h2 class="text-2xl font-semibold text-foreground">Table of contents</h2>
        <ul class="list-disc space-y-2 pl-6 text-foreground/75">
          <li><a href="#what-is-being-measured">What is being measured</a></li>
          <li><a href="#benchmark-overview">Benchmark overview</a></li>
          <li><a href="#score-categories">Score categories</a></li>
          <li><a href="#key-findings">Key findings</a></li>
          <li><a href="#related-score-tables-and-comparisons">Related score tables and comparisons</a></li>
          <li><a href="#methodology-and-trust">Methodology and trust</a></li>
        </ul>
      </nav>
      <div class="grid gap-8">
        <section class="space-y-3">
          <h2 id="what-is-being-measured" class="text-2xl font-semibold text-foreground">What is being measured</h2>
          <p class="text-foreground/75">Content Operations Benchmark assesses the efficiency and effectiveness of content processes within small service businesses in Austin. Key areas measured include content planning, creation, distribution, and performance analysis.</p>
          <p class="text-foreground/75">The benchmark model considers the entire content lifecycle, from initial ideation to post-publication analysis, ensuring a holistic view of content operations.</p>
        </section>
        <section class="space-y-3">
          <h2 id="benchmark-overview" class="text-2xl font-semibold text-foreground">Benchmark overview</h2>
          <p class="text-foreground/75">The benchmark model scores content operations across five categories: Strategy, Planning, Creation, Distribution, and Analysis. Each category is weighted based on its impact on overall content performance.</p>
          <p class="text-foreground/75">Austin&#39;s small service businesses can use this benchmark to identify strengths, weaknesses, and areas for improvement in their content operations.</p>
        </section>
        <section class="space-y-3">
          <h2 id="score-categories" class="text-2xl font-semibold text-foreground">Score categories</h2>
          <p class="text-foreground/75">1. **Strategy (20%)**: Aligns content goals with business objectives and considers target audience and market trends.</p>
          <p class="text-foreground/75">2. **Planning (25%)**: Ensures efficient content scheduling, resource allocation, and stakeholder communication.</p>
          <p class="text-foreground/75">3. **Creation (30%)**: Evaluates content quality, consistency, and adherence to brand guidelines.</p>
          <p class="text-foreground/75">4. **Distribution (15%)**: Assesses content reach, engagement, and channel optimization.</p>
          <p class="text-foreground/75">5. **Analysis (10%)**: Measures content performance, identifies trends, and facilitates data-driven decision making.</p>
        </section>
        <section class="space-y-3">
          <h2 id="key-findings" class="text-2xl font-semibold text-foreground">Key findings</h2>
          <p class="text-foreground/75">Austin&#39;s small service businesses excel in content creation (mean score: 7.8/10) but struggle with strategic planning (mean score: 5.2/10).</p>
          <p class="text-foreground/75">Local businesses with a clear content strategy and well-defined processes achieve higher scores and better content performance.</p>
        </section>
        <section class="space-y-3">
          <h2 id="related-score-tables-and-comparisons" class="text-2xl font-semibold text-foreground">Related score tables and comparisons</h2>
          <p class="text-foreground/75">Detailed score tables and comparisons are available in the [Content Operations Score Table](/content-operations-score-table) and [Content Operations Comparison](/content-operations-comparison) pages.</p>
          <p class="text-foreground/75">These resources help Austin&#39;s marketing leads benchmark their content operations against local and national averages.</p>
        </section>
        <section class="space-y-3">
          <h2 id="methodology-and-trust" class="text-2xl font-semibold text-foreground">Methodology and trust</h2>
          <p class="text-foreground/75">The Content Operations Benchmark uses a robust, multi-step methodology to ensure accurate and reliable results. Learn more about our approach in the [Methodology and Trust](/content-operations-methodology) page.</p>
          <p class="text-foreground/75">Our team of experts in content strategy, creation, and analysis ensures the benchmark&#39;s validity and relevance to Austin&#39;s small service businesses.</p>
        </section>
      </div>
      <section class="space-y-3">
        <h2 class="text-2xl font-semibold text-foreground">Related links</h2>
        <ul class="list-disc space-y-2 pl-6 text-foreground/75">
          <li><a href="https://protonbraulio.github.io/lt-20260519-063743875-devosfera-benchmark-audit-pa-3a00f4d9/content-operations-score-table">Content Operations Score Table</a></li>
          <li><a href="https://protonbraulio.github.io/lt-20260519-063743875-devosfera-benchmark-audit-pa-3a00f4d9/content-operations-comparison">Content Operations Comparison</a></li>
          <li><a href="https://protonbraulio.github.io/lt-20260519-063743875-devosfera-benchmark-audit-pa-3a00f4d9/content-operations-findings">Content Operations Findings</a></li>
          <li><a href="https://protonbraulio.github.io/lt-20260519-063743875-devosfera-benchmark-audit-pa-3a00f4d9/content-operations-faq">Content Operations FAQ</a></li>
          <li><a href="https://protonbraulio.github.io/lt-20260519-063743875-devosfera-benchmark-audit-pa-3a00f4d9/content-operations-methodology">Content Operations Methodology</a></li>
        </ul>
      </section>
      <div class="rounded border p-6 border-border/30">
        <h2 class="text-2xl font-semibold text-foreground">Next step</h2>
        <p class="mt-3 text-foreground/75">Talk to Devosfera Load Test 03 20260519-063743875 Benchmark Audit about content operations in Austin.</p>
      </div>
    </section>
</main>
  <Footer />
</Layout>

<style>
  /* ── Hero title shimmer ── */
  .hero-title {
    background: linear-gradient(
      135deg,
      var(--accent) 0%,
      color-mix(in oklab, var(--accent) 50%, var(--foreground)) 20%,
      var(--foreground) 35%,
      var(--foreground) 65%,
      color-mix(in oklab, var(--accent) 50%, var(--foreground)) 80%,
      var(--accent) 100%
    );
    background-size: 250% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 6s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%,
    100% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    // ── Card glow follow cursor ──
    document.querySelectorAll<HTMLElement>(".card-glow").forEach(card => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
      });
    });
  });
</script>
